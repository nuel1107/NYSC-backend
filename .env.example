# Copy this to .env and fill in your values
# NEVER commit .env to git

# Neon Postgres connection string
DATABASE_URL=postgres://username:password@ep-xxx.us-east-2.aws.neon.tech/triflow?sslmode=require

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-a-long-random-secret

# Your Vercel frontend URL
FRONTEND_URL=https://your-app.vercel.app

# Cloudflare R2 (or any S3-compatible storage)
S3_ENDPOINT_URL=https://ACCOUNT_ID.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=your-r2-access-key
S3_SECRET_ACCESS_KEY=your-r2-secret-key
S3_BUCKET_NAME=triflow-media
S3_PUBLIC_BASE_URL=https://pub-xxx.r2.dev
